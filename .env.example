# pi-bridge environment configuration
# Copy to .env and adjust values for your Pi, then export in systemd or shell.
# Do NOT commit .env to version control.

# Flask bind address — 0.0.0.0 listens on all interfaces (Tailscale reaches Pi by its tailnet IP)
PI_BRIDGE_HOST=0.0.0.0

# HTTP port
PI_BRIDGE_PORT=8080

# Absolute or repo-relative paths to scripts on the Pi
PI_BRIDGE_STATUS_SCRIPT=./scripts/status.sh
PI_BRIDGE_WAKE_SCRIPT=./scripts/wake.sh
PI_BRIDGE_SUSPEND_SCRIPT=./scripts/suspend.sh

# Max seconds to wait for any single script invocation before returning a 500
PI_BRIDGE_SCRIPT_TIMEOUT=30
